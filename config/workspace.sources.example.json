{
  "workspace_root": "../..",
  "knowledge_base_root": "../../../kb",
  "memory_db": ".workspace-os/workspace-memory.sqlite3",
  "oce_extensions": [
    "../src/workspace_os/oce_extension_adaptive_learning.py"
  ],
  "modeling": {
    "enabled": false,
    "default_profile": "none",
    "fallback_profile": "none",
    "profiles": {
      "remote_reasoner": {
        "kind": "openai_compatible",
        "enabled": true,
        "base_url_env": "WOS_MODEL_BASE_URL",
        "api_key_env": "WOS_MODEL_API_KEY",
        "model_env": "WOS_MODEL_NAME"
      }
    },
    "routes": {
      "planning": [
        "remote_reasoner"
      ],
      "review": [
        "remote_reasoner"
      ]
    }
  },
  "sources": [
    {
      "name": "adev",
      "type": "doctrine",
      "responsibility": "Operating doctrine, validation standards, and delivery guardrails.",
      "group": "knowledge_base",
      "path": "adev",
      "search": true
    },
    {
      "name": "scanales-kb",
      "type": "evidence",
      "responsibility": "Sanitized evidence, implementation notes, decisions, and verified lessons.",
      "group": "knowledge_base",
      "path": "scanales-kb",
      "search": true,
      "required": false
    },
    {
      "name": "homedir",
      "type": "execution",
      "responsibility": "Local workstation automation, scripts, and execution assets.",
      "group": "workspace",
      "path": "homedir",
      "search": true
    },
    {
      "name": "workspace-os",
      "type": "product",
      "responsibility": "Product roadmap, architecture, and workspace controller implementation.",
      "group": "workspace",
      "path": "workspace-os",
      "search": true
    }
  ]
}
